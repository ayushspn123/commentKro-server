NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/commentplease
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_ACCESS_SECRET=your-32-char-access-secret-here!!
JWT_REFRESH_SECRET=your-32-char-refresh-secret-here!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=my_custom_verify_token
META_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/meta/callback

ENCRYPTION_KEY=exactly-32-chars-for-aes-256!!

FRONTEND_URL=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Comment Please <your@gmail.com>

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

LOG_LEVEL=debug
