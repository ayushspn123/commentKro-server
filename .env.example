# ─── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/comment-please?retryWrites=true&w=majority

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_token_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Meta / Facebook App ─────────────────────────────────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v18.0
META_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token

# ─── Encryption (AES-256-GCM) ────────────────────────────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=your_32_char_encryption_key_here!

# ─── OAuth Callback ──────────────────────────────────────────────────
META_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/meta/callback
FRONTEND_URL=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=debug
