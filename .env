NODE_ENV=development
PORT=5000

# ── Local MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/comment-please

# ── Redis (local) ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=local_dev_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=local_dev_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Meta (fill these after creating a Meta app) ──────────────────────
META_APP_ID=2771340883238214
META_APP_SECRET=37e5e7531dbee13003a6d0de3b41d959
META_GRAPH_API_VERSION=v18.0
META_WEBHOOK_VERIFY_TOKEN=my_local_webhook_verify_token

# ── Token Encryption (exactly 32 chars) ─────────────────────────────
ENCRYPTION_KEY=local_dev_encrypt_key_32chars!!!

# ── OAuth Callback ───────────────────────────────────────────────────
META_OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/meta/callback
FRONTEND_URL=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=debug
